rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    /*
    ==============================================
    users
    ==============================================
    */

    match /users/{userId} {

      // 본인만 자신의 프로필 접근 가능

      allow read, write:

      if request.auth != null

      && request.auth.uid == userId;

      /*
      -----------------------------------------
      운동 기록
      -----------------------------------------
      */

      match /workouts/{date} {

        allow read, write:

        if request.auth != null

        && request.auth.uid == userId;

      }

    }

    /*
    ==============================================
    그 외 접근 금지
    ==============================================
    */

    match /{document=**} {

      allow read, write: if false;

    }

  }

}
